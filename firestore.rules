rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // 1. GLOBAL SAFETY NET
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // 2. GLOBAL HELPERS
    // ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "phonkphonkswe@gmail.com"
      );
    }

    // ---------------------------------------------------------
    // 3. VALIDATION BLUEPRINTS
    // ---------------------------------------------------------
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.username is string && data.username.size() <= 50 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('robux' in data) || data.robux is number) &&
             (!('drovis' in data) || data.drovis is number) &&
             (!('friends' in data) || (data.friends is list && data.friends.size() <= 1000)) &&
             (data.uid == request.auth.uid);
    }

    function isValidGame(data) {
      return data.keys().hasAll(['id', 'title', 'creatorUid']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.creatorUid is string && data.creatorUid == request.auth.uid &&
             (!('likes' in data) || data.likes is string) &&
             (!('playing' in data) || data.playing is number);
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['id', 'url', 'creatorUid']) &&
             data.id is string && data.id.size() <= 128 &&
             data.url is string && data.url.size() <= 500 &&
             data.creatorUid is string && data.creatorUid == request.auth.uid;
    }

    // ---------------------------------------------------------
    // 4. COLLECTION MATCH BLOCKS
    // ---------------------------------------------------------

    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid; // Prevent bulk scraping
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'displayName', 'username', 'avatarConfig', 'settings', 'gallery', 'isUpdated'
                    ]);
    }

    // Users by Username (Index)
    match /users_by_username/{username} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    // Games Collection
    match /games/{gameId} {
      allow read: if true;
      allow create: if isValidId(gameId) && isValidGame(incoming());
      allow update: if (existing().creatorUid == request.auth.uid || isAdmin()) && 
                    isValidGame(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'title', 'thumbnail', 'likes', 'playing', 'mapData', 'skybox'
                    ]);
      allow delete: if existing().creatorUid == request.auth.uid || isAdmin();
    }

    // Videos Collection
    match /videos/{videoId} {
      allow read: if true;
      allow create: if isValidId(videoId) && isValidVideo(incoming());
      allow update: if isSignedIn() && (
                      (existing().creatorUid == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['url', 'creatorName'])) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['likes'])) // Logic for liking
                    );
      allow delete: if existing().creatorUid == request.auth.uid || isAdmin();
    }

    // Studio Maps
    match /studio_maps/{username} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Add more strictness if username can be mapped to UID
    }

    // Global Settings
    match /global_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
